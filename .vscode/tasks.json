{
    "tasks": [
          {
            "label": "Build Slay The Console",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args":[

                 "-fdiagnostics-color=always",
                "-g",

                "main.cpp",
                "src/game_logic/*.cpp",
                "src/character/*.cpp",
                "src/card/*.cpp",
                "src/ui/*.cpp",
                "src/data/*.cpp",

                "-Iinclude",

                "-static",
                "-static-libgcc",
                "-static-libstdc++",

                "-o",
                "SLAY.exe"               
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }   
        
    ],
    "version": "2.0.0"
}